# SimpleMem — local-only project memory (committed store at docs/simplemem/)
SIMPLEMEM_ENABLED=true
SIMPLEMEM_BACKEND=local
SIMPLEMEM_NAMESPACE=mckenna-derby
SIMPLEMEM_LOCAL_DIR=docs/simplemem
SIMPLEMEM_DRY_RUN=false

# Optional cloud backend (not used by default)
# SIMPLEMEM_BACKEND=mcp
# SIMPLEMEM_MCP_URL=https://mcp.simplemem.cloud/mcp
# SIMPLEMEM_TOKEN=
# SIMPLEMEM_USER_ID=
